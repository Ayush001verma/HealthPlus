# Gemini API Key (Required for all AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Model name to use (defaults to gemini-1.5-flash)
MODEL_NAME=gemini-1.5-flash

# Backend Port (defaults to 3001)
PORT=3001

# Mappls API Credentials (Required for nearby pharmacies)
# You can use EITHER the single static API Key, OR the Client ID + Secret
MAPPLS_API_KEY=your_static_api_key_here
MAPPLS_CLIENT_ID=your_mappls_client_id_here
MAPPLS_CLIENT_SECRET=your_mappls_client_secret_here

